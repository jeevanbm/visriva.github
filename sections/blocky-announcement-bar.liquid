<link href="https://cdn.jsdelivr.net/npm/glidejs@2.1.0/dist/css/glide.core.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@glidejs/glide"></script>
<script src="{{ 'blocky-image-video-slider.js' | asset_url }}" defer></script>

<style>
.bky-annc {
  --bg: {{ section.settings.background_color }};
  --tc: {{ section.settings.text_color }};
  --fs: {{ section.settings.font_size }}px;
  --fsm: {{ section.settings.font_size_mobile }}px;
  --py: {{ section.settings.padding_y }}px;
  background: var(--bg);
}
.bky-annc .bky-annc-bar {
  padding-block: var(--py);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  {% if section.settings.max_width != blank %}
    max-width: {{section.settings.max_width}}px;
  {% endif %}
}
.bky-annc .glide__slides { align-items: center; margin: 0; }
.bky-annc .bky-annc-msg {
  color: var(--tc);
  font-size: var(--fsm);
  line-height: 1;
  font-weight: 700;
  letter-spacing: .06em;
  text-transform: uppercase;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 1em;
  white-space: nowrap;
  vertical-align: middle;
}
.bky-annc .bky-annc-msg img{
  height: 1em;
  margin-right: 5px;
}
@media (min-width: 750px){
  .bky-annc .bky-annc-msg { font-size: var(--fs); }
  .bky-annc .glide__arrow.blocky-slider-arrows-left{
    left: -3rem;   
  }
  .bky-annc .glide__arrow.blocky-slider-arrows-right{
    right: -3rem; 
  }
}
/* optional arrows (tiny) */
.bky-annc .glide__arrows { display: flex; align-items: center; }
.bky-annc .glide__arrow {
  background: transparent;
  border: 0; 
  padding: .25rem .5rem; 
  cursor: pointer;
  color: var(--tc); opacity: .6;
  box-shadow: none;
}
.bky-annc .glide__arrow.blocky-slider-arrows-left{
  transform: translate(-100%, -50%);
  left: 0;   
}
.bky-annc .glide__arrow.blocky-slider-arrows-right{
  transform: translate(100%, -50%);
  right: 0;
}

.bky-annc .glide__arrow:hover { opacity: 1; }
.bky-annc .glide__bullets { display: none; } /* no dots for announcement */
</style>

<div class="bky-annc">
  <div class="bky-annc-bar blocky-slider blocky-page-width">
    <blocky-media-slider
      class="glide ivs-{{ section.id }}"
      data-id="{{ section.id }}"
      data-size="{{ section.blocks.size }}"
      slide-size="1"
      mobile-slide-size="1"
      media-spacing="0"
      data-review
      data-anim-duration="{{ section.settings.anim_duration }}"
      data-anim-easing="{{ section.settings.anim_easing }}" 
      {% if section.settings.autoplay_enabled %}data-auto data-auto-interval="{{ section.settings.autoplay_interval | times: 1000 }}"{% endif %}
    >
      <div class="glide__track" data-glide-el="track">
        <ul class="glide__slides">
          {% for block in section.blocks %}
            <li class="glide__slide" {{ block.shopify_attributes }}>
              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="bky-annc-msg">
                  {% if block.settings.icon != blank %}
                    <img class="bky-annc-icon" src="{{ block.settings.icon | image_url: width: 64, height: 64, crop: 'center' }}" alt="">
                  {% endif %}
                  {{ block.settings.message | escape }}
                </a>
              {% else %}
                <span class="bky-annc-msg">
                  {% if block.settings.icon != blank %}
                    <img class="bky-annc-icon" src="{{ block.settings.icon | image_url: width: 64, height: 64, crop: 'center' }}" alt="">
                  {% endif %}
                  {{ block.settings.message | escape }}
                </span>
              {% endif %}
            </li>
          {% endfor %}
        </ul>
      </div>
      {% if section.settings.show_arrows %}
      <div class="glide__arrows" data-glide-el="controls" aria-label="Announcement navigation">
        <button class="glide__arrow glide__arrow--prev blocky-slider-arrows-center blocky-slider-arrows-left" data-glide-dir="<" aria-label="Previous">‹</button>
        <button class="glide__arrow glide__arrow--next  blocky-slider-arrows-center blocky-slider-arrows-right" data-glide-dir=">" aria-label="Next">›</button>
      </div>
      {% endif %}
    </blocky-media-slider>
  </div>
</div>

{% schema %}
{
  "name": "BKY Announcement Bar",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Appearance" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#111111" },
    { "type": "range", "id": "font_size", "label": "Desktop Font size", "min": 12, "max": 28, "default": 18, "unit": "px" },
    { "type": "range", "id": "font_size_mobile", "label": "Mobile Font size", "min": 10, "max": 24, "default": 14, "unit": "px" },
    { "type": "range", "id": "padding_y", "label": "Vertical padding", "min": 6, "max": 28, "default": 12, "unit": "px" },

    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "autoplay_enabled", "label": "Enable autoplay", "default": true },
    { "type": "range", "id": "autoplay_interval", "label": "Autoplay interval (sec)", "min": 2, "max": 12, "default": 4, "unit": "s" },
    { "type": "checkbox", "id": "show_arrows", "label": "Show arrows", "default": false },

    { "type": "header", "content": "Animation" },
    { "type": "range", "id": "anim_duration", "label": "Slide duration (ms)", "min": 200, "max": 2000, "step": 100, "default": 300, "unit": "ms" },
    { "type": "select", "id": "anim_easing", "label": "Easing", "default": "ease-out", "options": [
      { "value": "ease-out", "label": "Ease out (gentle)" },
      { "value": "ease", "label": "Ease" },
      { "value": "ease-in-out", "label": "Ease in-out" },
      { "value": "linear", "label": "Linear" }
    ] },
    { "type": "number", "id": "max_width", "label": "Max Width of Announcement Bar in px (optional)"}
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Announcement",
      "settings": [
        { "type": "text", "id": "message", "label": "Message", "default": "Free shipping on all orders!" },
        { "type": "url", "id": "link", "label": "Optional link" },
        { "type": "image_picker", "id": "icon", "label": "Optional icon/logo (left of text)" }
      ]
    }
  ],
  "presets": [
    { "name": "Blocky Announcement Bar", "blocks": [ { "type": "slide" }, { "type": "slide" } ] }
  ]
}
{% endschema %}
