<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@glidejs/glide@3.6.1/dist/css/glide.core.min.css">
<script src="https://cdn.jsdelivr.net/npm/@glidejs/glide@3.6.1/dist/glide.min.js" defer></script>
<script src="{{ 'blocky-product-slider.js' | asset_url }}" defer></script>

{%- liquid
  assign section_id = 'product-slider-' | append: section.id
  assign desktop_slide_height = 450
  if section.settings.slides_per_view == 4
    assign desktop_slide_height = 550
  elsif section.settings.slides_per_view == 6
    assign desktop_slide_height = 400
  endif
-%}

{% capture slide_to_render %}
  {%- for block in section.blocks -%}
    {%- if block.type != 'slide' -%}
      {%- continue -%}
    {%- endif -%}
    {%- liquid
      assign media_type = block.settings.media_type
      assign slide_product = block.settings.product
      assign use_custom_image = block.settings.use_custom_image
      assign custom_img = block.settings.custom_image
    -%}
    <li class="glide__slide product-slider-slide" {{ block.shopify_attributes }}>
      <div class="product-slider-slide__media" style="border-color: {{ section.settings.media_border_color }};">
        {%- if media_type == 'video' and block.settings.video != blank -%}
          <div class="product-slider-slide__video-wrap">
            <video preload="true" muted class="product-slider-slide__video" poster="{{ block.settings.video.preview_image | image_url: width: 800 }}">
              {% for source in block.settings.video.sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
            </video>
          </div>
          <button
            type="button"
            class="product-slider-slide__sound-toggle"
            aria-label="Toggle sound"
            data-sound-toggle
          >
            <span class="product-slider-slide__sound-icon product-slider-slide__sound-icon--muted" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11 5L7 9H4v6h3l4 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <path d="M16 9l4 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M20 9l-4 6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
            <span class="product-slider-slide__sound-icon product-slider-slide__sound-icon--on" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M11 5L7 9H4v6h3l4 4V5z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                <path d="M15.5 8.5c1.5 1.5 1.5 5.5 0 7" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                <path d="M18 6c3 3 3 9 0 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
              </svg>
            </span>
          </button>
        {%- elsif media_type == 'image' and block.settings.image != blank -%}
          <div class="product-slider-slide__img-wrap">
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag: loading: 'lazy', widths: '400, 600, 800', class: 'product-slider-slide__img'
            }}
          </div>
        {%- elsif media_type == 'image' and block.settings.image == blank -%}
          <div class="product-slider-slide__img-wrap product-slider-slide__placeholder">
            {{ 'image' | placeholder_svg_tag: 'product-slider-slide__placeholder-svg' }}
          </div>
        {%- elsif media_type == 'video' and block.settings.video == blank -%}
          <div class="product-slider-slide__placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'product-slider-slide__placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

      {%- if slide_product != blank -%}
        <a
          href="{{ slide_product.url }}"
          class="product-slider-slide__box"
          style="border-color: {{ section.settings.product_box_border_color }}; color: {{ section.settings.text_color }};"
        >
          <div class="product-slider-slide__box-img-wrap">
            {%- if use_custom_image and custom_img != blank -%}
              {{
                custom_img
                | image_url: width: 200
                | image_tag:
                  loading: 'lazy',
                  widths: '100, 200',
                  class: 'product-slider-slide__box-img',
                  alt: slide_product.title
              }}
            {%- elsif slide_product.featured_image != blank -%}
              {{
                slide_product.featured_image
                | image_url: width: 200
                | image_tag:
                  loading: 'lazy',
                  widths: '100, 200',
                  class: 'product-slider-slide__box-img',
                  alt: slide_product.title
              }}
            {%- endif -%}
          </div>
          <div class="product-slider-slide__box-info">
            <span class="product-slider-slide__box-title">{{ slide_product.title }}</span>
            <span class="product-slider-slide__box-price">
              {%- if slide_product.compare_at_price > slide_product.price -%}
                <span class="product-slider-slide__box-price--compare">
                  {{- slide_product.compare_at_price | money -}}
                </span>
                <span class="product-slider-slide__box-price--current">
                  {{- slide_product.price | money -}}
                </span>
              {%- else -%}
                {{ slide_product.price | money }}
              {%- endif -%}
            </span>
          </div>
        </a>
      {%- endif -%}
    </li>
  {%- endfor -%}
{% endcapture %}

<style>
  blocky-product-slider {
    display: block;
  }

  .product-slider-section__header {
    margin-bottom: 2rem;
    text-align: center;
  }

  .product-slider-slide {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    user-select: none;
    -webkit-user-drag: none;
    justify-content: center;
  }

  .product-slider-slide__media {
    border-radius: var(--ps-slide-border-radius);
    border: 1px solid var(--ps-media-border);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: #f5f5f5;
    position: relative;
    transition: aspect-ratio 0 ease;
    transition-duration: var(--ps-transition-ms, 500ms);
    transition-delay: 0ms;
  }

  .product-slider-slide__video-wrap,
  .product-slider-slide__img-wrap {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .product-slider-slide__video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-slider-slide__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-slider-slide__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .product-slider-slide__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.4;
  }

  .product-slider-slide__sound-toggle {
    position: absolute;
    right: 10px;
    bottom: 10px;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    background: rgba(0, 0, 0, 0.35);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    line-height: 0;
    cursor: pointer;
    z-index: 2;
    -webkit-tap-highlight-color: transparent;
  }

  .product-slider-slide__sound-toggle:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .product-slider-slide__sound-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
  }

  .product-slider-slide__sound-icon svg {
    display: block;
  }

  .product-slider-slide__sound-icon--on {
    display: none;
  }

  .is-sound-on .product-slider-slide__sound-icon--muted {
    display: none;
  }

  .is-sound-on .product-slider-slide__sound-icon--on {
    display: inline;
  }

  .product-slider-slide__box {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border-radius: var(--ps-box-border-radius);
    border: 1px solid var(--ps-box-border);
    background: var(--ps-box-bg);
    text-decoration: none;
    transition: opacity 0.2s;
    color: var(--ps-text);
  }

  .product-slider-slide__box-img-wrap {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: var(--ps-box-border-radius);
    overflow: hidden;
    background: #f5f5f5;
  }

  .product-slider-slide__box-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-slider-slide__box-info {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .product-slider-slide__box-title {
    font-weight: 600;
    font-size: var(--ps-title-size, 0.95rem);
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-slider-slide__box-price {
    font-size: var(--ps-price-size, 0.9rem);
  }

  .product-slider-slide__box-price--compare {
    text-decoration: line-through;
    opacity: 0.7;
    margin-right: 0.35rem;
  }

  .glide__slides {
    align-items: stretch;
    padding-block: 5px;
  }

  .product-slider-glide .glide__track {
    touch-action: pan-y;
  }

  .product-slider-slide__video::-webkit-media-controls {
    display: none !important;
  }

  .product-slider-slide__video::-webkit-media-controls-panel {
    display: none !important;
  }

  .product-slider-slide__video::-webkit-media-controls-play-button {
    display: none !important;
  }

  .product-slider-slide__video::-webkit-media-controls-start-playback-button {
    display: none !important;
  }

  .product-slider-slide__video::-webkit-media-controls-enclosure {
    display: none !important;
  }

  @media (max-width: 600px) {
    .product-slider-slide__media {
      aspect-ratio: 3 / 5;
    }
  }

  @media (min-width: 990px) {
    .product-slider-slide {
      height: var(--ps-slide-height, 450px);
    }

    .glide__slide.is-current .product-slider-slide__media {
      aspect-ratio: 3 / 5;
    }

    .product-slider-glide .glide__track {
      cursor: grab;
    }

    .product-slider-glide.glide--dragging .glide__track {
      cursor: grabbing;
    }
  }
</style>

<blocky-product-slider
  id="{{ section_id }}"
  class="blocky blocky-padding background-wrapper"
  style="
    --padding-top: {{ section.settings.padding_top }};
    --padding-bottom: {{ section.settings.padding_bottom }};
    --background-color: {{ section.settings.background_color }};
    --section-page-width: {{ section.settings.page_width }}px;
    --ps-text: {{ section.settings.text_color }};
    --ps-media-border: {{ section.settings.media_border_color }};
    --ps-box-border: {{ section.settings.product_box_border_color }};
    --ps-box-bg: {{ section.settings.product_box_background_color }};
    --ps-slide-border-radius: {{ section.settings.slide_border_radius }}px;
    --ps-box-border-radius: {{ section.settings.product_box_border_radius }}px;
    --ps-gap: {{ section.settings.gap | default: 16 }}px;
    --ps-transition-ms: {{ section.settings.animation_duration_ms | default: 500 }}ms;
    --ps-title-size: {{ section.settings.product_title_font_size | default: 15 }}px;
    --ps-price-size: {{ section.settings.product_price_font_size | default: 14 }}px;
    --ps-slide-height: {{ desktop_slide_height }}px;
  "
  data-animation-ms="{{ section.settings.animation_duration_ms }}"
  data-video-autoplay="{{ section.settings.video_autoplay_active }}"
  data-video-muted="{{ section.settings.video_muted_default }}"
  data-video-loop="{{ section.settings.video_loop }}"
>
  <div class="blocky-page-width">
    {%- if section.settings.title != blank or section.settings.body_text != blank -%}
      <div class="product-slider-section__header blocky-media-text-container blocky-text-container-desktop-{{ section.settings.desktop_content_alignment }} blocky-text-container-mobile-{{ section.settings.mobile_content_alignment }}">
        {% render 'blocky-titlel', block: section %}
        {% render 'blocky-bodyl', block: section %}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div
        class="glide product-slider-glide"
        data-slides-per-view="{{ section.settings.slides_per_view }}"
        data-autoplay="{{ section.settings.autoplay }}"
        data-autoplay-speed="{{ section.settings.autoplay_speed }}"
      >
        <div class="glide__track" data-glide-el="track">
          <ul class="glide__slides">
            {{ slide_to_render }}
          </ul>
        </div>
      </div>
    {%- endif -%}
  </div>
</blocky-product-slider>

{% schema %}
{
  "name": "BKY - Product Slider",
  "tag": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [

    { "type": "header", "content": "General" },
    {
      "type": "inline_richtext",
      "id": "title",
      "label": "Title",
      "default": "<b>Product Slider</b>"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "min": 28,
      "max": 96,
      "step": 1,
      "default": 40,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#1a1a1a"
    },

    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body",
      "default": "<p>Swipe through our featured products</p>"
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 12,
      "max": 26,
      "step": 1,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#1a1a1a"
    },

    {
      "type": "select",
      "id": "desktop_content_alignment",
      "label": "Desktop content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "select",
      "id": "mobile_content_alignment",
      "label": "Mobile content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },

    { "type": "header", "content": "Slider" },
    {
      "type": "range",
      "id": "slides_per_view",
      "min": 4,
      "max": 6,
      "step": 1,
      "default": 5,
      "label": "Slides per view (desktop)"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2000,
      "max": 9500,
      "step": 500,
      "unit": "ms",
      "default": 3000,
      "label": "Autoplay speed"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 16,
      "unit": "px",
      "label": "Slide gap"
    },
    {
      "type": "range",
      "id": "animation_duration_ms",
      "min": 200,
      "max": 1200,
      "step": 50,
      "default": 700,
      "unit": "ms",
      "label": "Desktop slide animation duration"
    },

    { "type": "header", "content": "Video" },
    {
      "type": "checkbox",
      "id": "video_autoplay_active",
      "label": "Autoplay active slide video",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_muted_default",
      "label": "Start videos muted",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "video_loop",
      "label": "Loop videos",
      "default": true
    },

    { "type": "header", "content": "Product box" },
    {
      "type": "range",
      "id": "product_title_font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Product title font size",
      "default": 15
    },
    {
      "type": "range",
      "id": "product_price_font_size",
      "min": 11,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Product price font size",
      "default": 14
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "product_box_border_color",
      "label": "Product box border color",
      "default": "#e0e0e0"
    },
    {
      "type": "color",
      "id": "product_box_background_color",
      "label": "Product box background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "product_box_border_radius",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Product box border radius",
      "default": 8
    },

    { "type": "header", "content": "Card style" },
    {
      "type": "color",
      "id": "media_border_color",
      "label": "Media border color",
      "default": "#e0e0e0"
    },
    {
      "type": "range",
      "id": "slide_border_radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "label": "Slide border radius",
      "default": 12
    },

    { "type": "header", "content": "Section settings" },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f7f7f7"
    },
    {
      "type": "range",
      "id": "page_width",
      "label": "Section width",
      "min": 800,
      "max": 1600,
      "step": 100,
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "visible_if": "{{ block.settings.media_type == 'image' }}"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "visible_if": "{{ block.settings.media_type == 'video' }}"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "checkbox",
          "id": "use_custom_image",
          "label": "Use custom product image",
          "default": false,
          "info": "If unchecked, the product's main image is used in the box below."
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom product image",
          "info": "Shown in the product box when 'Use custom product image' is enabled."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Blocky Product Slider",
      "blocks": [
        { "type": "slide" },
        { "type": "slide" },
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}
