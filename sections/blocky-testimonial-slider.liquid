    {
      "type": "inline_richtext",
      "id": "title",
      "default": "<b>What Our Customers Say</b>",
      "label": "Title",
      "info": "Leave the text blank to hide the title."
    },

    {
      "type": "range",
      "id": "title_size",
      "label": "Title size",
      "default": 60,
      "min": 30,
      "max": 100,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "default": "<p>100,000+ Reviews • 3M+ Customers</p>",
      "label": "Body",
      "info": "Leave the text blank to hide the body."
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "default": 16,
      "min": 10,
      "max": 30,
