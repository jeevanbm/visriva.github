{{ 'custom-tshirt-designer.css' | asset_url | stylesheet_tag }}

{% comment %} T-Shirt Customizer Section {% endcomment %}

<style>
  .tshirt-customizer {
    background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
    border-radius: 20px;
    padding: 2rem;
    margin: 2rem 0;
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
  }

  .customizer-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .customizer-header h3 {
    font-size: 1.8rem;
    color: #1a1a2e;
    margin-bottom: 0.5rem;
    font-weight: 700;
  }

  .customizer-header p {
    color: #666;
    font-size: 0.95rem;
  }

  .customizer-container {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 2rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .customizer-container {
      grid-template-columns: 1fr;
    }
  }

  .tshirt-preview-area {
    position: relative;
    background: white;
    border-radius: 16px;
    padding: 2rem;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 450px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .tshirt-container {
    position: relative;
    width: 240px;
    height: 260px;
  }

  .tshirt-base {
    width: 100%;
    height: 100%;
  }

  .design-overlay {
    position: absolute;
    top: 48%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 70px;
    height: 70px;
    cursor: move;
    border: 2px dashed rgba(0,81,61,0.5);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    background: rgba(255,255,255,0.5);
  }

  .design-overlay:hover {
    border-color: #00513D;
    background: rgba(0,81,61,0.05);
  }

  .design-overlay.has-design {
    border-style: solid;
    border-color: #00513D;
    background: transparent;
  }

  .design-overlay img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
  }

  .design-placeholder {
    text-align: center;
    color: #888;
    font-size: 0.8rem;
  }

  .design-placeholder svg {
    width: 32px;
    height: 32px;
    margin-bottom: 0.4rem;
    stroke: #aaa;
  }

  .design-placeholder p {
    font-weight: 500;
    margin: 0.25rem 0;
    color: #666;
  }

  .design-placeholder span {
    font-size: 0.7rem;
    color: #999;
  }

  .customizer-controls {
    background: white;
    border-radius: 16px;
    padding: 1.5rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }

  .control-section {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .control-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .control-section h4 {
    font-size: 0.9rem;
    color: #1a1a2e;
    margin-bottom: 1rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .control-section h4 svg {
    width: 18px;
    height: 18px;
    color: #00513D;
  }

  .upload-area {
    border: 2px dashed #ddd;
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    cursor: pointer;
    transition: all 0.3s ease;
    background: #fafafa;
  }

  .upload-area:hover {
    border-color: #00513D;
    background: rgba(0,81,61,0.03);
  }

  .upload-area.dragover {
    border-color: #00513D;
    background: rgba(0,81,61,0.05);
    transform: scale(1.02);
  }

  .upload-area svg {
    width: 48px;
    height: 48px;
    color: #00513D;
    margin-bottom: 1rem;
  }

  .upload-area p {
    color: #666;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .upload-area span {
    color: #999;
    font-size: 0.8rem;
  }

  .upload-area input[type="file"] {
    display: none;
  }

  .color-options {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 0.75rem;
  }

  .color-option {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    cursor: pointer;
    border: 3px solid transparent;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  }

  .color-option:hover {
    transform: scale(1.1);
  }

  .color-option.active {
    border-color: #00513D;
    box-shadow: 0 0 0 3px rgba(0,81,61,0.3);
  }

  .size-slider {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .size-slider input[type="range"] {
    flex: 1;
    height: 6px;
    border-radius: 3px;
    background: #ddd;
    appearance: none;
    cursor: pointer;
  }

  .size-slider input[type="range"]::-webkit-slider-thumb {
    appearance: none;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    background: #00513D;
    cursor: pointer;
    box-shadow: 0 2px 6px rgba(0,81,61,0.3);
  }

  .size-value {
    min-width: 50px;
    text-align: center;
    font-weight: 600;
    color: #1a1a2e;
    font-size: 0.9rem;
  }

  .position-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .position-btn {
    padding: 0.75rem;
    border: 1px solid #ddd;
    border-radius: 8px;
    background: white;
    cursor: pointer;
    font-size: 0.8rem;
    color: #666;
    transition: all 0.2s ease;
  }

  .position-btn:hover {
    border-color: #00513D;
    color: #00513D;
  }

  .position-btn.active {
    background: #00513D;
    color: white;
    border-color: #00513D;
  }

  .clear-design-btn {
    width: 100%;
    padding: 0.9rem;
    background: #fff;
    border: 2px solid #ff4444;
    border-radius: 10px;
    color: #ff4444;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 1rem;
  }

  .clear-design-btn:hover {
    background: #ff4444;
    color: white;
  }

  .clear-design-btn svg {
    width: 18px;
    height: 18px;
  }

  .design-price {
    margin-top: 1.5rem;
    padding: 1rem;
    background: linear-gradient(135deg, #00513D 0%, #003d2e 100%);
    border-radius: 12px;
    color: white;
    text-align: center;
  }

  .design-price p {
    font-size: 0.85rem;
    opacity: 0.9;
    margin-bottom: 0.25rem;
  }

  .design-price span {
    font-size: 1.5rem;
    font-weight: 700;
  }

  /* Resize handles */
  .resize-handle {
    position: absolute;
    width: 12px;
    height: 12px;
    background: #00513D;
    border: 2px solid white;
    border-radius: 50%;
    cursor: nwse-resize;
    z-index: 10;
  }

  .resize-handle.top-left { top: -6px; left: -6px; cursor: nwse-resize; }
  .resize-handle.top-right { top: -6px; right: -6px; cursor: nesw-resize; }
  .resize-handle.bottom-left { bottom: -6px; left: -6px; cursor: nesw-resize; }
  .resize-handle.bottom-right { bottom: -6px; right: -6px; cursor: nwse-resize; }

  /* Icons */
  .icon-upload { stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .icon-palette { stroke: currentColor; fill: none; stroke-width: 2; }
  .icon-move { stroke: currentColor; fill: none; stroke-width: 2; }
  .icon-resize { stroke: currentColor; fill: none; stroke-width: 2; }
  .icon-trash { stroke: currentColor; fill: none; stroke-width: 2; }
</style>

<div class="tshirt-customizer" id="tshirt-customizer-{{ product.id }}">
  <div class="customizer-header">
    <h3>🎨 Customize Your T-Shirt</h3>
    <p>Upload your design and preview it on your tee</p>
  </div>

  <div class="customizer-container">
    <div class="tshirt-preview-area">
      <div class="tshirt-container" id="tshirt-container-{{ product.id }}">
        <svg viewBox="0 0 240 260" class="tshirt-base" id="tshirt-base-{{ product.id }}">
          <!-- Simple flat T-shirt design -->
          <g fill="var(--tshirt-color, #ffffff)" stroke="var(--tshirt-stroke, #cccccc)" stroke-width="1.5" stroke-linejoin="round">
            <!-- Left sleeve -->
            <path d="M45 55 L15 95 L35 105 L55 75 Z"/>
            <!-- Right sleeve -->
            <path d="M195 55 L225 95 L205 105 L185 75 Z"/>
            <!-- Main body -->
            <path d="M55 45 L45 55 L55 75 L60 200 L180 200 L185 75 L195 55 L185 45 Q150 40 115 45 Z"/>
          </g>
          <!-- Collar V-neck -->
          <path d="M95 45 Q120 55 145 45 Q140 35 120 38 Q100 35 95 45"
                fill="var(--tshirt-color, #ffffff)"
                stroke="var(--tshirt-stroke, #cccccc)"
                stroke-width="1"/>
          <!-- Simple collar line -->
          <path d="M95 45 L100 42 Q120 50 140 42 L145 45"
                fill="none"
                stroke="var(--tshirt-stroke, #cccccc)"
                stroke-width="1"/>
          <!-- Print area -->
          <rect x="75" y="70" width="90" height="85" rx="3"
                fill="none"
                stroke="rgba(180,180,180,0.5)"
                stroke-width="1"
                stroke-dasharray="5,5"/>
        </svg>
        <div
          class="design-overlay"
          id="design-overlay-{{ product.id }}"
          data-position-x="50"
          data-position-y="48"
          data-size="70"
        >
          <div class="design-placeholder" id="design-placeholder-{{ product.id }}">
            <svg viewBox="0 0 24 24" class="icon-upload">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
              <polyline points="17 8 12 3 7 8"/>
              <line x1="12" y1="3" x2="12" y2="15"/>
            </svg>
            <p>Your Design</p>
            <span>Click to upload</span>
          </div>
        </div>
      </div>
    </div>

    <div class="customizer-controls">
      <div class="control-section">
        <h4>
          <svg viewBox="0 0 24 24" class="icon-upload"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          Upload Design
        </h4>
        <div class="upload-area" id="upload-area-{{ product.id }}">
          <svg viewBox="0 0 24 24" class="icon-upload">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="17 8 12 3 7 8"/>
            <line x1="12" y1="3" x2="12" y2="15"/>
          </svg>
          <p>Drop your image here or click to browse</p>
          <span>PNG, JPG, SVG (Max 5MB)</span>
          <input type="file" id="file-input-{{ product.id }}" accept="image/png,image/jpeg,image/svg+xml">
        </div>
      </div>

      <div class="control-section">
        <h4>
          <svg viewBox="0 0 24 24" class="icon-palette"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
          T-Shirt Color
        </h4>
        <div class="color-options">
          <div class="color-option active" data-color="#ffffff" data-stroke="#e0e0e0" title="White"></div>
          <div class="color-option" data-color="#000000" data-stroke="#333333" title="Black"></div>
          <div class="color-option" data-color="#2c3e50" data-stroke="#1a252f" title="Navy"></div>
          <div class="color-option" data-color="#e74c3c" data-stroke="#c0392b" title="Red"></div>
          <div class="color-option" data-color="#3498db" data-stroke="#2980b9" title="Blue"></div>
          <div class="color-option" data-color="#27ae60" data-stroke="#1e8449" title="Green"></div>
          <div class="color-option" data-color="#f39c12" data-stroke="#d68910" title="Yellow"></div>
          <div class="color-option" data-color="#9b59b6" data-stroke="#8e44ad" title="Purple"></div>
          <div class="color-option" data-color="#e91e63" data-stroke="#c2185b" title="Pink"></div>
          <div class="color-option" data-color="#00bcd4" data-stroke="#0097a7" title="Cyan"></div>
          <div class="color-option" data-color="#795548" data-stroke="#5d4037" title="Brown"></div>
          <div class="color-option" data-color="#607d8b" data-stroke="#455a64" title="Grey"></div>
        </div>
      </div>

      <div class="control-section">
        <h4>
          <svg viewBox="0 0 24 24" class="icon-move"><polyline points="5 9 2 12 5 15"/><polyline points="9 5 12 2 15 5"/><polyline points="15 19 12 22 9 19"/><polyline points="19 9 22 12 19 15"/><line x1="2" y1="12" x2="22" y2="12"/><line x1="12" y1="2" x2="12" y2="22"/></svg>
          Design Size
        </h4>
        <div class="size-slider">
          <input type="range" id="size-slider-{{ product.id }}" min="40" max="200" value="120">
          <span class="size-value" id="size-value-{{ product.id }}">120px</span>
        </div>
      </div>

      <div class="control-section">
        <h4>
          <svg viewBox="0 0 24 24" class="icon-move"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="9" y1="3" x2="9" y2="21"/><line x1="15" y1="3" x2="15" y2="21"/></svg>
          Position
        </h4>
        <div class="position-grid">
          <button class="position-btn" data-x="25" data-y="25">Top Left</button>
          <button class="position-btn" data-x="50" data-y="25">Top Center</button>
          <button class="position-btn" data-x="75" data-y="25">Top Right</button>
          <button class="position-btn" data-x="25" data-y="35">Center Left</button>
          <button class="position-btn active" data-x="50" data-y="35">Center</button>
          <button class="position-btn" data-x="75" data-y="35">Center Right</button>
          <button class="position-btn" data-x="25" data-y="50">Bottom Left</button>
          <button class="position-btn" data-x="50" data-y="50">Bottom Center</button>
          <button class="position-btn" data-x="75" data-y="50">Bottom Right</button>
        </div>
      </div>

      <button class="clear-design-btn" id="clear-btn-{{ product.id }}" style="display: none;">
        <svg viewBox="0 0 24 24" class="icon-trash"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
        Clear Design
      </button>

      <div class="design-price">
        <p>Custom Design Fee</p>
        <span>+₹200</span>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  const productId = '{{ product.id }}';
  const container = document.getElementById('tshirt-container-' + productId);
  const overlay = document.getElementById('design-overlay-' + productId);
  const fileInput = document.getElementById('file-input-' + productId);
  const uploadArea = document.getElementById('upload-area-' + productId);
  const sizeSlider = document.getElementById('size-slider-' + productId);
  const sizeValue = document.getElementById('size-value-' + productId);
  const clearBtn = document.getElementById('clear-btn-' + productId);
  const tshirtBase = document.getElementById('tshirt-base-' + productId);

  let currentDesign = null;
  let isDragging = false;
  let isResizing = false;
  let startX, startY, startPosX, startPosY, startSize;

  // File upload handlers
  uploadArea.addEventListener('click', () => fileInput.click());

  uploadArea.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadArea.classList.add('dragover');
  });

  uploadArea.addEventListener('dragleave', () => {
    uploadArea.classList.remove('dragover');
  });

  uploadArea.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadArea.classList.remove('dragover');
    const file = e.dataTransfer.files[0];
    if (file && file.type.match(/image.*/)) {
      handleFile(file);
    }
  });

  fileInput.addEventListener('change', (e) => {
    const file = e.target.files[0];
    if (file) handleFile(file);
  });

  function handleFile(file) {
    if (file.size > 5 * 1024 * 1024) {
      alert('File too large! Maximum size is 5MB.');
      return;
    }

    const reader = new FileReader();
    reader.onload = (e) => {
      const img = document.createElement('img');
      img.src = e.target.result;
      img.onload = () => {
        currentDesign = e.target.result;
        overlay.innerHTML = '<img src="' + currentDesign + '" alt="Your Design">';
        overlay.classList.add('has-design');
        clearBtn.style.display = 'flex';
        addResizeHandles();
      };
    };
    reader.readAsDataURL(file);
  }

  // Clear design
  clearBtn.addEventListener('click', () => {
    currentDesign = null;
    overlay.innerHTML = `
      <div class="design-placeholder" id="design-placeholder-${productId}">
        <svg viewBox="0 0 24 24" class="icon-upload">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="17 8 12 3 7 8"/>
          <line x1="12" y1="3" x2="12" y2="15"/>
        </svg>
        <p>Your Design</p>
        <span>Click or drag to upload</span>
      </div>
    `;
    overlay.classList.remove('has-design');
    clearBtn.style.display = 'none';
    removeResizeHandles();
  });

  // Size slider
  sizeSlider.addEventListener('input', (e) => {
    const size = e.target.value;
    sizeValue.textContent = size + 'px';
    overlay.style.width = size + 'px';
    overlay.style.height = size + 'px';
    overlay.dataset.size = size;
  });

  // Color options
  document.querySelectorAll('.color-option').forEach(option => {
    option.addEventListener('click', () => {
      document.querySelectorAll('.color-option').forEach(o => o.classList.remove('active'));
      option.classList.add('active');
      tshirtBase.style.setProperty('--tshirt-color', option.dataset.color);
      tshirtBase.style.setProperty('--tshirt-stroke', option.dataset.stroke);
    });
  });

  // Position buttons
  document.querySelectorAll('.position-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.position-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      const x = btn.dataset.x;
      const y = btn.dataset.y;
      overlay.style.left = x + '%';
      overlay.style.top = y + '%';
      overlay.style.transform = 'translate(-50%, -50%)';
      overlay.dataset.positionX = x;
      overlay.dataset.positionY = y;
    });
  });

  // Drag functionality
  overlay.addEventListener('mousedown', (e) => {
    if (e.target.classList.contains('resize-handle')) {
      isResizing = true;
      startSize = parseInt(overlay.style.width) || 120;
    } else {
      isDragging = true;
    }
    startX = e.clientX;
    startY = e.clientY;
    startPosX = parseFloat(overlay.style.left) || 50;
    startPosY = parseFloat(overlay.style.top) || 35;
  });

  document.addEventListener('mousemove', (e) => {
    if (isDragging) {
      const dx = e.clientX - startX;
      const dy = e.clientY - startY;
      const containerRect = container.getBoundingClientRect();
      const newX = startPosX + (dx / containerRect.width) * 100;
      const newY = startPosY + (dy / containerRect.height) * 100;
      overlay.style.left = Math.max(5, Math.min(95, newX)) + '%';
      overlay.style.top = Math.max(5, Math.min(95, newY)) + '%';
    }
    if (isResizing) {
      const dy = e.clientY - startY;
      const newSize = Math.max(40, Math.min(200, startSize + dy));
      overlay.style.width = newSize + 'px';
      overlay.style.height = newSize + 'px';
      sizeSlider.value = newSize;
      sizeValue.textContent = newSize + 'px';
    }
  });

  document.addEventListener('mouseup', () => {
    isDragging = false;
    isResizing = false;
  });

  function addResizeHandles() {
    const handles = ['top-left', 'top-right', 'bottom-left', 'bottom-right'];
    handles.forEach(pos => {
      const handle = document.createElement('div');
      handle.className = 'resize-handle ' + pos;
      overlay.appendChild(handle);
    });
  }

  function removeResizeHandles() {
    overlay.querySelectorAll('.resize-handle').forEach(h => h.remove());
  }
})();
</script>