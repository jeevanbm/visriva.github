        { "type": "color", "id": "block_heading_color", "label": "Block Heading Color", "default": "#32999E" },
        { "type": "range", "id": "block_heading_font_size", "label": "Block Heading Font Size", "default": 17, "min": 10, "max": 25, "step": 1, "unit": "px" },
        { "type": "color", "id": "block_description_color", "label": "Block Description Color", "default": "#555" },
        { "type": "range", "id": "block_description_font_size", "label": "Block Description Font Size", "default": 14, "min": 10, "max": 15, "step": 1, "unit": "px" },
