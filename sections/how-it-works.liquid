{% stylesheet %}
  .blocky-how-it-works .blocky-media-adapt .bky-vid-placeholder {
    height: 45rem;
    max-height: 480px;
  }

  @media (max-width: 768px) {
    .blocky-how-it-works .blocky-media-adapt .bky-vid-placeholder {
      height: 30rem;
      max-height: 320px;
    }
  }

  .blocky-how-it-works .how-steps { 
    padding-left: 58px; 
  }

  .blocky-how-it-works .how-steps-line {
    display: block;
    position: absolute; 
    top: 0; 
    left: 18px; 
    width:2px; 
    z-index: 1;
    background: var(--timeline-background-color, #194C4F);
  }

  .blocky-how-it-works .how-step { 
    position: relative; 
    margin-bottom: 20px; 
    display: flex; 
    flex-direction: column; 
  }
  .blocky-how-it-works .how-step:last-child { 
    margin-bottom: 0; 
  }

  .blocky-how-it-works .how-step-number {
    position: absolute; 
    left: -55px; 
    top: 2px; 
    z-index: 1; 
    width: 32px; 
    height: 32px; 
    border-radius: 50%;
    display:flex; 
    align-items:center; 
    justify-content:center; 
    font-weight:700; 
    box-shadow: 0 0 0 3px #fff, 0 0 0 4px #000;
    background-color: var(--how-number-bg); 
    color: var(--how-number-color); 
    font-size: var(--how-number-size);
  }
  .blocky-how-it-works .how-step-text .heading { 
    font-weight: 700; 
    line-height: 1.35; 
    margin: 0 0 5px; 
    color: var(--how-block-heading-color); 
    font-size: var(--how-block-heading-size); 
  }
  .blocky-how-it-works .how-step-text .desc { 
    margin: 0; 
    line-height: 1.4; 
    color: var(--how-block-desc-color); 
    font-size: var(--how-block-desc-size); 
  }
{% endstylesheet %}
<script src="{{ 'blocky-video.js' | asset_url }}" defer></script>

<div 
  class="blocky blocky-how-it-works blocky-padding background-wrapper"
  style="
    --padding-top: {{ section.settings.padding_top }}; 
    --padding-bottom: {{ section.settings.padding_bottom }}; 
    --background-color: {{ section.settings.background_color }}; 
    --section-page-width: {{ section.settings.page_width | divided_by: 10 }}rem; 
    --text-container-gap: {{ section.settings.text_container_gap }};
  "
>
  <div class="blocky-page-width">
    <div class="blocky-flex-container blocky-mob-flex-{{ section.settings.mobile_layout }} blocky-des-flex-{{ section.settings.layout }} blocky-flex-layout-1">

      
      {%- for block in section.blocks -%}
        {%- if block.type == 'media' -%}
          <div class="blocky-flex-child blocky-flex-child-{{ block.settings.desktop_media_width }} blocky-align-{{ block.settings.desktop_media_position }} blocky-media-{{ block.settings.media_height }} blocky-rounded-sm {% if block.settings.shadow == true %} blocky-shadow {% endif %} blocky-overflow-hidden" style="{% if block.settings.show_border == true %}border: 1px solid {{ block.settings.border_color }};{% endif %}" {{ block.shopify_attributes }}>
            {%- if block.settings.video != blank -%}
              {% render 'blocky-video', 
                video: block.settings.video, 
                video_fit: block.settings.media_fit, 
                autoplay: block.settings.autoplay, 
                button_color: block.settings.play_button_color, 
                background_button_color: block.settings.play_button_background_color 
              %}
            {%- elsif block.settings.image != blank -%}
              {%- assign img = block.settings.image -%}
              <img
                class="blocky-media blocky-image-{{ block.settings.media_height }} {% if block.settings.media_fit == "zoomed" %} blocky-video-zoomed{% endif %}"
                src="{{ img | image_url: height: 750 }}"
              >  
            {% else %}
              <div class="blocky-video blocky-shadow bky-vid-placeholder" style="--play-button-color: white; --play-button-background-color: lightgrey">
                <button class="blocky-video-play-button">
                  <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 100 100">
                    <circle cx="50" cy="50" r="48" stroke="fill" stroke-width="2" class="background"/>
                    <polygon 
                      points="35,25 75,50 35,75"
                      stroke-width="2"
                      stroke-linejoin="round"
                      class="play-button"
                    /> 
                  </svg>  
                </button>
              </div>
            {%- endif -%}
          </div>
        {% endif %}
      {% endfor %}
      
      <div class="blocky-flex-child blocky-flex-child-2">
        <div class="blocky-media-text-container blocky-align-{{ section.settings.desktop_content_position }} blocky-text-container-desktop-{{ section.settings.desktop_content_alignment }} blocky-text-container-mobile-{{ section.settings.mobile_content_alignment }}">
          {%- if section.settings.main_heading != blank -%}
            <h2 class="blocky-title" style="--title-size: {{ section.settings.main_heading_font_size }}; --title-color: {{ section.settings.main_heading_color }}">{{ section.settings.main_heading }}</h2>
          {%- endif -%}
          {%- if section.settings.subheading != blank -%}
            <div class="blocky-body-text" style="--body-color: {{ section.settings.subheading_color }}; --body-font-size: {{ section.settings.subheading_font_size }}px">
              <p>{{ section.settings.subheading }}</p>
            </div>
          {%- endif -%}
          {%- if section.settings.sub_subheading != blank -%}
            <div class="blocky-body-text" style="--body-color: {{ section.settings.sub_subheading_color }}; --body-font-size: {{ section.settings.sub_subheading_font_size }}px">
              <p><strong>{{ section.settings.sub_subheading }}</strong></p>
            </div>
          {%- endif -%}


          {% for block in section.blocks -%}
            {%- if block.type == 'timeline' -%}
              <div class="how-steps blocky-relative"
                style="    
                  --timeline-background-color: {{ block.settings.timeline_background_color }};
                  --how-block-heading-color: {{ block.settings.block_heading_color }};
                  --how-block-heading-size: {{ block.settings.block_heading_font_size }}px;
                  --how-block-desc-color: {{ block.settings.block_description_color }};
                  --how-block-desc-size: {{ block.settings.block_description_font_size }}px;
                  --how-number-bg: {{ block.settings.number_block_background_color }};
                  --how-number-color: {{ block.settings.number_block_text_color }};
                  --how-number-size: {{ block.settings.number_block_font_size }}px;
                "
                {{ block.shopify_attributes }}
              >
                <div class="how-steps-line" aria-hidden="true"></div>
                {%- for i in (1..7) -%}
                  {%- assign heading = "block_heading" | append: i -%}
                  {%- assign heading = block.settings[heading] -%}
                  {%- assign text = "block_text" | append: i -%}
                  {%- assign text = block.settings[text] -%}
                  {%- if heading != blank -%}
                    <div class="how-step">
                      <div class="how-step-number">{{ i }}</div>
                      <div class="how-step-text">
                        <h3 class="heading">{{ heading }}</h3>
                        {%- if text != blank -%}
                          <p class="desc">{{ text }}</p>
                        {%- endif -%}
                      </div>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            {% endif %}
          {% endfor %}


        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function(){
    function updateTimeline(container){
      try{
        var line = container.querySelector('.how-steps-line');
        var last = container.querySelector('.how-step:last-child .how-step-number');
        if(!line || !last) return;
        var tRect = container.getBoundingClientRect();
        var bRect = last.getBoundingClientRect();
        var height = (bRect.bottom - tRect.top);
        line.style.height = height + 'px';
      }catch(e){}
    }
    function initAll(){
      document.querySelectorAll('.blocky-how-it-works .how-steps').forEach(updateTimeline);
    }
    window.addEventListener('DOMContentLoaded', initAll);
    window.addEventListener('resize', initAll);
    document.addEventListener('shopify:section:load', initAll);
    document.addEventListener('shopify:section:select', initAll);
  })();
</script>

{% schema %}
{
  "name": "BKY - How It Works",
  "settings": [
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "main_heading", "label": "Main Heading", "default": "How It Works" },
