        { "type": "color", "id": "number_block_text_color", "label": "Number Block Text Color", "default": "#fff" },
        { "type": "range", "id": "number_block_font_size", "label": "Number Block Font Size", "default": 18, "min": 10, "max": 40, "step": 1, "unit": "px" },
