    { "type": "color", "id": "main_heading_color", "label": "Main Heading Color", "default": "#0D2628" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Each step is designed to bring out your skin’s natural glow and keep it protected." },
    { "type": "range", "id": "subheading_font_size", "label": "Subheading Font Size", "default": 16, "min": 10, "max": 40, "step": 1, "unit": "px" },
    { "type": "color", "id": "subheading_color", "label": "Subheading Color", "default": "#505257" },
    { "type": "textarea", "id": "sub_subheading", "label": "Sub Subheading", "default": "HERE’S WHAT HAPPENS:" },
    { "type": "range", "id": "sub_subheading_font_size", "label": "Sub Subheading Font Size", "default": 16, "min": 10, "max": 40, "step": 1, "unit": "px" },
