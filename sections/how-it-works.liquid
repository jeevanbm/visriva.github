      "settings": [
        { "type": "video", "id": "video", "label": "Video" },
        { "type": "image_picker", "id": "image", "label": "Image (optional)" },
        { "type": "text", "id": "alt_text", "label": "Image alt text" },
        { "type": "select", "id": "media_height", "label": "Height", "default": "adapt", "options": [
          {"value":"adapt","label":"Adapt to media"},
          {"value":"small","label":"Small"},
          {"value":"medium","label":"Medium"},
          {"value":"large","label":"Large"}
        ]},
        { "type": "select", "id": "desktop_media_width", "label": "Width", "default": "medium", "options": [
          {"value":"small","label":"Small"},
          {"value":"medium","label":"Medium"},
          {"value":"large","label":"Large"}
        ]},
        { "type": "select", "id": "desktop_media_position", "label": "Desktop position", "default": "center", "options": [
          {"value":"start","label":"Top"},
          {"value":"center","label":"Middle"},
          {"value":"end","label":"Bottom"}
        ]},
        { "type": "select", "id": "media_fit", "label": "Media fit", "default": "zoomed", "options": [
          {"value":"fit","label":"Fit"},
          {"value":"zoomed","label":"Zoomed in"}
        ]},
        { "type": "checkbox", "id": "shadow", "label": "Show media shadow", "default": true },
        { "type": "checkbox", "id": "show_border", "label": "Show border", "default": false },
        { "type": "color", "id": "border_color", "label": "Border color", "default": "#000000", "visible_if": "{{ block.settings.show_border == true }}" },
