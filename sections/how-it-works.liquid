      {"value":"col-reverse","label":"Text first"}
    ]},
    { "type": "select", "id": "text_container_gap", "label": "Space between text", "default": "1.5rem", "options": [
      {"label":"None","value":"0"},
      {"label":"Small","value":"0.5rem"},
      {"label":"Medium","value":"1rem"},
      {"label":"Large","value":"1.5rem"},
      {"label":"Extra Large","value":"2rem"}
    ]},

    { "type": "header", "content": "Section size" },
    { "type": "range", "id": "page_width", "label": "Section width", "unit": "px", "step": 100, "min": 800, "max": 1600, "default": 1200 },
    { "type": "range", "id": "padding_top", "label": "Top padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding", "min": 0, "max": 100, "step": 4, "unit": "px", "default": 36 }
  ],
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [
