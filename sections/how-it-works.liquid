        { "type": "text", "id": "block_heading2", "label": "Step 2 Heading", "default": "Activate" },
        { "type": "textarea", "id": "block_text2", "label": "Step 2 Text", "default": "Key ingredients begin targeting the skin’s surface" },
        { "type": "text", "id": "block_heading3", "label": "Step 3 Heading", "default": "Penetrate" },
        { "type": "textarea", "id": "block_text3", "label": "Step 3 Text", "default": "The formula reaches deeper layers for maximum impact" },
        { "type": "text", "id": "block_heading4", "label": "Step 4 Heading", "default": "Repair" },
        { "type": "textarea", "id": "block_text4", "label": "Step 4 Text", "default": "Skin is soothed, renewed, and supported" },
        { "type": "text", "id": "block_heading5", "label": "Step 5 Heading", "default": "Protect" },
        { "type": "textarea", "id": "block_text5", "label": "Step 5 Text", "default": "A barrier locks in hydration and shields against stressors" },
        { "type": "text", "id": "block_heading6", "label": "Step 6 Heading", "default": "Glow" },
        { "type": "textarea", "id": "block_text6", "label": "Step 6 Text", "default": "Radiance and confidence shine through with consistent use" },
        { "type": "text", "id": "block_heading7", "label": "Step 7 Heading" },
        { "type": "textarea", "id": "block_text7", "label": "Step 7 Text" }
      ]
