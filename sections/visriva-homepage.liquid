{% comment %}
  VISRIVA - Luxury Fashion Homepage
  Complete theme structure with textured gradient background
{% endcomment %}

{{ 'visriva-luxury.css' | asset_url | stylesheet_tag }}

{%- comment -%} VISRIVA Grain Texture SVG Filter {%- endcomment -%}
<svg class="visriva-grain-svg" aria-hidden="true">
  <filter id="grain-filter" x="0%" y="0%" width="100%" height="100%">
    <feTurbulence type="fractalNoise" baseFrequency="0.8" numOctaves="4" stitchTiles="stitch" result="noise"/>
    <feColorMatrix type="saturate" values="0" in="noise" result="monoNoise"/>
    <feBlend in="SourceGraphic" in2="monoNoise" mode="multiply" result="blend"/>
    <feBlend in="blend" in2="monoNoise" mode="screen"/>
  </filter>
</svg>

<div class="visriva-wrapper">

  {% comment %} ===== HEADER ===== {% endcomment %}
  <header class="visriva-header">
    <nav class="visriva-nav">
      <a href="/" class="visriva-logo" aria-label="VISRIVA Home">
        {%- if settings.logo != blank -%}
          <img src="{{ settings.logo | image_url: height: 60 }}" alt="{{ shop.name }}" class="visriva-logo-img">
        {%- else -%}
          <span class="visriva-wordmark">VISRIVA</span>
        {%- endif -%}
      </a>
      <button class="visriva-menu-toggle" aria-label="Menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </header>

  {% comment %} ===== HERO SECTION ===== {% endcomment %}
  <section class="visriva-hero">
    <div class="visriva-hero-video-container">
      {%- if section.settings.hero_video != blank -%}
        <video class="visriva-hero-video" autoplay muted loop playsinline poster="{{ section.settings.hero_poster | image_url }}">
          <source src="{{ section.settings.hero_video }}" type="video/mp4">
        </video>
      {%- elsif section.settings.hero_image -%}
        <img src="{{ section.settings.hero_image | image_url: width: 1920 }}" alt="" class="visriva-hero-image">
      {%- endif -%}
      <div class="visriva-hero-overlay"></div>
    </div>
    <div class="visriva-hero-content">
      <h1 class="visriva-hero-title">
        <span class="visriva-hero-title-line" style="--delay: 0">{{ section.settings.hero_title | default: 'Eternal Elegance' }}</span>
      </h1>
      <div class="visriva-hero-cta">
        <a href="{{ section.settings.hero_link | default: '/collections/all' }}" class="visriva-btn visriva-btn-outline">
          {{ section.settings.hero_button_text | default: 'Shop the Collection' }}
          <span class="visriva-btn-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
    <div class="visriva-hero-scroll-indicator">
      <span>Scroll</span>
      <div class="visriva-scroll-line"></div>
    </div>
  </section>

  {% comment %} ===== PHILOSOPHY SECTION ===== {% endcomment %}
  <section class="visriva-philosophy">
    <div class="visriva-container">
      <div class="visriva-philosophy-content">
        <span class="visriva-label">{{ section.settings.philosophy_label | default: 'The Art of Dressing' }}</span>
        <h2 class="visriva-philosophy-title">{{ section.settings.philosophy_title | default: 'Where Heritage Meets Horizon' }}</h2>
        <p class="visriva-philosophy-text">{{ section.settings.philosophy_text | default: 'VISRIVA represents the convergence of timeless craftsmanship and contemporary vision. Each piece tells a story of meticulous attention to detail.' }}</p>
      </div>
    </div>
  </section>

  {% comment %} ===== DYNAMIC COLLECTION GRID ===== {% endcomment %}
  <section class="visriva-collection">
    <div class="visriva-container">
      <header class="visriva-collection-header">
        <span class="visriva-label">{{ section.settings.collection_label | default: 'Curated Selection' }}</span>
        <h2 class="visriva-collection-title">
          {%- comment -%} Ancient Linguistics Title {%- endcomment -%}
          {{ section.settings.collection_title | default: 'Novitates Primordialis' }}
        </h2>
        <p class="visriva-collection-subtitle">
          {{ section.settings.collection_subtitle | default: 'The first of a new beginning — our latest arrivals embody the essence of contemporary luxury.' }}
        </p>
      </header>

      <div class="visriva-product-grid">
        {%- comment -%} Dynamic Product Loop {%- endcomment -%}
        {%- assign product_limit = section.settings.products_count | default: 4 -%}
        {%- assign collection_handle = section.settings.collection_handle | default: 'frontpage' -%}
        {%- assign product_collection = collections[collection_handle] -%}
        {%- for product in product_collection.products limit: product_limit -%}
          <article class="visriva-product-card" data-animate>
            <a href="{{ product.url }}" class="visriva-product-link">
              <div class="visriva-product-media">
                {%- if product.featured_image -%}
                  <img
                    src="{{ product.featured_image | image_url: width: 600, height: 800 }}"
                    alt="{{ product.title }}"
                    class="visriva-product-image"
                    loading="{{ forloop.index | plus: 1 }}"
                  >
                {%- else -%}
                  <div class="visriva-product-placeholder">
                    <span>{{ product.title }}</span>
                  </div>
                {%- endif -%}
                <div class="visriva-product-overlay">
                  <span class="visriva-product-view">View Details</span>
                </div>
              </div>
              <div class="visriva-product-info">
                <span class="visriva-product-vendor">{{ product.vendor }}</span>
                <h3 class="visriva-product-title">{{ product.title }}</h3>
                <div class="visriva-product-price">
                  {%- if product.price_varies -%}
                    <span class="visriva-price-from">From</span>
                  {%- endif -%}
                  <span class="visriva-price">{{ product.price | money }}</span>
                  {%- if product.compare_at_price > product.price -%}
                    <span class="visriva-price-compare">{{ product.compare_at_price | money }}</span>
                  {%- endif -%}
                </div>
              </div>
            </a>
            {%- if product.available == false -%}
              <span class="visriva-product-badge visriva-badge-soldout">Sold Out</span>
            {%- elsif product.tags contains 'new' -%}
              <span class="visriva-product-badge visriva-badge-new">New</span>
            {%- endif -%}
          </article>
        {%- else -%}
          {%- comment -%} Placeholder products when no collection exists {%- endcomment -%}
          {%- for i in (1..4) -%}
            <article class="visriva-product-card">
              <div class="visriva-product-media">
                <div class="visriva-product-placeholder">
                  <span>Product {{ i }}</span>
                </div>
              </div>
              <div class="visriva-product-info">
                <h3 class="visriva-product-title">Classic Ensemble {{ i }}</h3>
                <div class="visriva-product-price">
                  <span class="visriva-price">₹{{ 2400 | plus: forloop.index0 | times: 400 }}</span>
                </div>
              </div>
            </article>
          {%- endfor -%}
        {%- endfor -%}
      </div>

      <div class="visriva-collection-footer">
        <a href="{{ product_collection.url | default: '/collections/all' }}" class="visriva-btn visriva-btn-ghost">
          Explore All Pieces
          <span class="visriva-btn-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  {% comment %} ===== CRAFTSMANSHIP SECTION ===== {% endcomment %}
  <section class="visriva-craft">
    <div class="visriva-container">
      <div class="visriva-craft-grid">
        <div class="visriva-craft-content">
          <span class="visriva-label">{{ section.settings.craft_label | default: 'Our Commitment' }}</span>
          <h2 class="visriva-craft-title">{{ section.settings.craft_title | default: 'The Art of Craft' }}</h2>
          <p class="visriva-craft-text">{{ section.settings.craft_text | default: 'Every VISRIVA creation is a testament to the mastery of artisan craftspeople who have perfected their art over generations. We honor traditional techniques while embracing modern innovation.' }}</p>
          <ul class="visriva-craft-features">
            <li>
              <svg class="visriva-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 13l4 4L19 7"/>
              </svg>
              <span>Ethically sourced materials</span>
            </li>
            <li>
              <svg class="visriva-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 13l4 4L19 7"/>
              </svg>
              <span>Hand-finished details</span>
            </li>
            <li>
              <svg class="visriva-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M5 13l4 4L19 7"/>
              </svg>
              <span>Sustainable practices</span>
            </li>
          </ul>
        </div>
        <div class="visriva-craft-media">
          {%- if section.settings.craft_image -%}
            <img src="{{ section.settings.craft_image | image_url: width: 800 }}" alt="VISRIVA Craftsmanship">
          {%- else -%}
            <div class="visriva-craft-placeholder">
              <span>Craftsmanship</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {% comment %} ===== FOOTER ===== {% endcomment %}
  <footer class="visriva-footer">
    <div class="visriva-container">
      <div class="visriva-footer-top">
        <div class="visriva-footer-brand">
          <span class="visriva-wordmark">VISRIVA</span>
          <p class="visriva-footer-tagline">Luxury Reimagined</p>
        </div>
        <div class="visriva-footer-links">
          <div class="visriva-footer-col">
            <h4>Shop</h4>
            <ul>
              <li><a href="/collections/all">All Products</a></li>
              <li><a href="/collections/new-arrivals">New Arrivals</a></li>
              <li><a href="/collections/bestsellers">Bestsellers</a></li>
            </ul>
          </div>
          <div class="visriva-footer-col">
            <h4>Company</h4>
            <ul>
              <li><a href="/pages/about">Our Story</a></li>
              <li><a href="/pages/sustainability">Sustainability</a></li>
              <li><a href="/pages/contact">Contact</a></li>
            </ul>
          </div>
          <div class="visriva-footer-col">
            <h4>Support</h4>
            <ul>
              <li><a href="/pages/shipping">Shipping</a></li>
              <li><a href="/pages/returns">Returns</a></li>
              <li><a href="/pages/size-guide">Size Guide</a></li>
            </ul>
          </div>
        </div>
      </div>
      <div class="visriva-footer-bottom">
        <p>&copy; {{ 'now' | date: '%Y' }} VISRIVA. All rights reserved.</p>
        <div class="visriva-footer-social">
          <a href="#" aria-label="Instagram">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <circle cx="12" cy="12" r="4"/>
              <circle cx="18" cy="6" r="1"/>
            </svg>
          </a>
          <a href="#" aria-label="Twitter">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z"/>
            </svg>
          </a>
          <a href="#" aria-label="Pinterest">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"/>
              <path d="M8 12c0 2.21 1.79 4 4 4s4-1.79 4-4-1.79-4-4-4-4 1.79-4 4z"/>
              <path d="M12 16v6"/>
              <path d="M9 19l3 3 3-3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>
  </footer>

</div>

<style>
  /* ========== VISRIVA LUXURY CSS ========== */

  /* === CSS Variables === */
  :root {
    --v-navy: #0A1128;
    --v-forest: #013220;
    --v-gold: #D4AF37;
    --v-gold-light: #E5C76B;
    --v-cream: #F5F1E6;
    --v-white: #FFFFFF;
    --v-text-muted: rgba(245, 241, 230, 0.6);

    --v-font-heading: 'Cormorant Garamond', 'Times New Roman', serif;
    --v-font-body: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;

    --v-gold-border: 1px solid rgba(212, 175, 55, 0.3);
    --v-gold-glow: 0 0 20px rgba(212, 175, 55, 0.15);
    --v-transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* === Base Reset === */
  .visriva-wrapper {
    min-height: 100vh;
    background: linear-gradient(145deg, var(--v-navy) 0%, var(--v-forest) 100%);
    background-attachment: fixed;
    color: var(--v-cream);
    font-family: var(--v-font-body);
    overflow-x: hidden;
    position: relative;
  }

  /* === Luxury Grain Effect === */
  .visriva-wrapper::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 9999;
  }

  .visriva-grain-svg {
    position: absolute;
    width: 0;
    height: 0;
  }

  /* === Container === */
  .visriva-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  /* === Header === */
  .visriva-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1.5rem 0;
    background: linear-gradient(to bottom, rgba(10, 17, 40, 0.9) 0%, transparent 100%);
    backdrop-filter: blur(10px);
  }

  .visriva-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 clamp(1.5rem, 5vw, 4rem);
  }

  .visriva-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
  }

  .visriva-logo-img {
    height: 50px;
    width: auto;
    object-fit: contain;
  }

  .visriva-wordmark {
    font-family: var(--v-font-heading);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: 0.4em;
    color: var(--v-cream);
    text-transform: uppercase;
  }

  .visriva-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    position: absolute;
    right: 1.5rem;
  }

  .visriva-menu-toggle span {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--v-cream);
    margin: 6px 0;
    transition: var(--v-transition);
  }

  /* === Hero Section === */
  .visriva-hero {
    position: relative;
    height: 100vh;
    min-height: 700px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .visriva-hero-video-container {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .visriva-hero-video,
  .visriva-hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .visriva-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 17, 40, 0.4) 0%,
      rgba(1, 50, 32, 0.6) 50%,
      rgba(10, 17, 40, 0.95) 100%
    );
  }

  .visriva-hero-content {
    position: relative;
    z-index: 10;
    text-align: center;
    padding: 2rem;
  }

  .visriva-hero-title {
    font-family: var(--v-font-heading);
    font-size: clamp(3rem, 10vw, 8rem);
    font-weight: 300;
    line-height: 1.1;
    letter-spacing: 0.05em;
    margin-bottom: 2.5rem;
    opacity: 0;
    animation: visriva-fade-up 1.2s ease forwards;
  }

  .visriva-hero-title-line {
    display: block;
  }

  @keyframes visriva-fade-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .visriva-hero-cta {
    opacity: 0;
    animation: visriva-fade-up 1.2s ease 0.4s forwards;
  }

  .visriva-hero-scroll-indicator {
    position: absolute;
    bottom: 3rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    opacity: 0.6;
  }

  .visriva-scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to bottom, var(--v-gold) 0%, transparent 100%);
    animation: visriva-scroll 2s ease infinite;
  }

  @keyframes visriva-scroll {
    0%, 100% { opacity: 0.3; transform: scaleY(0.5); }
    50% { opacity: 1; transform: scaleY(1); }
  }

  /* === Buttons === */
  .visriva-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem 2.5rem;
    font-family: var(--v-font-body);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    transition: var(--v-transition);
  }

  .visriva-btn-outline {
    border: var(--v-gold-border);
    color: var(--v-gold);
    background: transparent;
  }

  .visriva-btn-outline:hover {
    background: var(--v-gold);
    color: var(--v-navy);
    box-shadow: var(--v-gold-glow);
  }

  .visriva-btn-ghost {
    border: 1px solid rgba(245, 241, 230, 0.3);
    color: var(--v-cream);
    background: transparent;
  }

  .visriva-btn-ghost:hover {
    border-color: var(--v-gold);
    color: var(--v-gold);
  }

  .visriva-btn-arrow svg {
    transition: transform 0.3s ease;
  }

  .visriva-btn:hover .visriva-btn-arrow svg {
    transform: translateX(5px);
  }

  /* === Label Style === */
  .visriva-label {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--v-gold);
    margin-bottom: 1rem;
  }

  /* === Philosophy Section === */
  .visriva-philosophy {
    padding: 8rem 0;
    text-align: center;
    position: relative;
  }

  .visriva-philosophy::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, transparent, var(--v-gold));
  }

  .visriva-philosophy-content {
    max-width: 700px;
    margin: 0 auto;
  }

  .visriva-philosophy-title {
    font-family: var(--v-font-heading);
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 300;
    line-height: 1.3;
    margin-bottom: 1.5rem;
  }

  .visriva-philosophy-text {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--v-text-muted);
  }

  /* === Collection Section === */
  .visriva-collection {
    padding: 6rem 0 10rem;
    background: linear-gradient(to bottom, transparent 0%, rgba(1, 50, 32, 0.3) 50%, transparent 100%);
  }

  .visriva-collection-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .visriva-collection-title {
    font-family: var(--v-font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 300;
    letter-spacing: 0.02em;
    margin-bottom: 1rem;
  }

  .visriva-collection-subtitle {
    max-width: 500px;
    margin: 0 auto;
    font-size: 1rem;
    color: var(--v-text-muted);
    line-height: 1.7;
  }

  /* === Product Grid === */
  .visriva-product-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: clamp(1rem, 3vw, 2rem);
  }

  @media (min-width: 768px) {
    .visriva-product-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* === Product Card === */
  .visriva-product-card {
    position: relative;
    opacity: 0;
    transform: translateY(30px);
    transition: var(--v-transition);
  }

  .visriva-product-card[data-animate] {
    animation: visriva-card-reveal 0.8s ease forwards;
  }

  .visriva-product-card:nth-child(1) { animation-delay: 0.1s; }
  .visriva-product-card:nth-child(2) { animation-delay: 0.2s; }
  .visriva-product-card:nth-child(3) { animation-delay: 0.3s; }
  .visriva-product-card:nth-child(4) { animation-delay: 0.4s; }

  @keyframes visriva-card-reveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .visriva-product-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .visriva-product-media {
    position: relative;
    aspect-ratio: 3/4;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
    margin-bottom: 1.25rem;
  }

  .visriva-product-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .visriva-product-card:hover .visriva-product-image {
    transform: scale(1.05);
  }

  .visriva-product-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(to top, rgba(10, 17, 40, 0.9) 0%, transparent 50%);
    opacity: 0;
    transition: var(--v-transition);
  }

  .visriva-product-card:hover .visriva-product-overlay {
    opacity: 1;
  }

  .visriva-product-view {
    padding: 0.75rem 1.5rem;
    border: var(--v-gold-border);
